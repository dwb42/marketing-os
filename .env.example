# Marketing OS — Environment Example
# Copy to .env and fill in.

# Core
NODE_ENV=development
LOG_LEVEL=info
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketing_os?schema=public

# Credential encryption key for IntegrationAccount.credentials (AES-256-GCM)
# 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
MOS_CREDENTIAL_KEY=

# Google Ads (Phase 3+)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=

# Meta Ads (Phase 5+)
META_APP_ID=
META_APP_SECRET=
